{
  "name": "voiceforge",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based AI voice agent — Groq STT/LLM + ElevenLabs TTS",
  "scripts": {
    "dev": "pnpm --parallel --recursive dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --recursive build",
    "build:shared": "pnpm --filter @voiceforge/shared build",
    "lint": "eslint 'apps/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint --fix 'apps/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.ts'",
    "format": "prettier --write 'apps/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'apps/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.ts'",
    "test": "pnpm --recursive --parallel run test",
    "typecheck": "pnpm --recursive run lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
